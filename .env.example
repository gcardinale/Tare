# Tare — esempio di variabili d'ambiente (copia in .env, che è gitignorato).
# I segreti reali NON vanno mai committati. La config vera vive in ~/.tare/config.jsonc.

# Porta del proxy loopback (default 3210)
# TARE_PORT=3210

# Endpoint del classifier locale (Ollama / llama.cpp / GGUF OpenAI-compatible)
# TARE_CLASSIFIER_ENDPOINT=http://127.0.0.1:8080/v1/chat/completions
